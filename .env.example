# ─────────────────────────────────────────────────────────────────────────────
# SOIL — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — used by the Paystack webhook to write orders (bypasses RLS)
# NEVER prefix with VITE_ — must not be exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Paystack (required for live payments) ────────────────────────────────────
# Found in: Paystack Dashboard → Settings → API Keys & Webhooks
#
# The SECRET key powers checkout AND verifies incoming webhooks — Paystack signs
# every webhook with this same key, so there is no separate "webhook secret".
# Use sk_test_... while testing, sk_live_... for real money.
PAYSTACK_SECRET_KEY=sk_test_...

# Register your webhook in: Paystack Dashboard → Settings → API Keys & Webhooks
#   Webhook URL:  https://your-domain.com/api/webhook
# (Paystack sends the `charge.success` event there after every paid order.)
#
# NOTE on currencies: the store can charge in Naira (NGN) and US Dollars (USD).
# NGN works on every Paystack account out of the box. To also charge in USD,
# your Paystack account must have USD/multicurrency ENABLED (ask Paystack support
# or enable it in the dashboard). Until then, keep USD checkout off in
# Admin → Settings → Payments & Currency.

# ── Resend — transactional email (order confirmations) ───────────────────────
# Found in: Resend Dashboard → API Keys
# If these are unset, orders still save fine — the webhook just skips email.
RESEND_API_KEY=re_...
# Must be an address on a domain you've VERIFIED in Resend → Domains.
# Format: "Display Name <address@your-domain.com>"
RESEND_FROM_EMAIL=SOIL Studio <orders@your-domain.com>
# Where new-order alerts are sent (e.g. Duke's inbox).
ADMIN_NOTIFICATION_EMAIL=you@your-domain.com

# ── Error monitoring (optional) ──────────────────────────────────────────────
# Paste a Sentry project DSN to turn on error reporting. Leave blank and it's
# completely off (no Sentry code is loaded). Create one free at sentry.io.
VITE_SENTRY_DSN=

# ── Checkout mode ─────────────────────────────────────────────────────────────
# Set to "true" to bypass Paystack and go straight to the success page (local dev only)
# Set to "false" (or remove) for live payments
VITE_MOCK_CHECKOUT=false

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Only needed locally if VERCEL_URL is not set.
# In production on Vercel, VERCEL_URL is set automatically.
# ALLOWED_ORIGIN=http://localhost:5173
